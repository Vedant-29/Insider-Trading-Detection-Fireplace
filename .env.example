# Polygon RPC via Alchemy (free tier)
# Get yours at https://www.alchemy.com → Create app → Polygon Mainnet
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Derived URLs (DO NOT EDIT — built from ALCHEMY_API_KEY)
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
# POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# Postgres connection
DATABASE_URL=postgres://localhost:5432/polymarket_insider

# Backfill window (in months back from current head)
BACKFILL_MONTHS=9

# Optional: override starting block for backfill (default: derived from BACKFILL_MONTHS)
# BACKFILL_START_BLOCK=
